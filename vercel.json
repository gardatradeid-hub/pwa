{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(assets|icons|exchanges|locales)/configs/(.*)",
      "destination": "/$1/configs/$2"
    },
    {
      "source": "/(assets|icons|exchanges|locales)/(.*)",
      "destination": "/$1/$2"
    },
    {
      "source": "/manifest.webmanifest",
      "destination": "/manifest.webmanifest"
    },
    {
      "source": "/registerSW.js",
      "destination": "/registerSW.js"
    },
    {
      "source": "/sw.js",
      "destination": "/sw.js"
    },
    {
      "source": "/workbox-(.*)",
      "destination": "/workbox-$1"
    },
    {
      "source": "/favicon.svg",
      "destination": "/favicon.svg"
    },
    {
      "source": "/((?!api).*)" ,
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_APP_URL": "https://garda-alpha.vercel.app"
  }
}
